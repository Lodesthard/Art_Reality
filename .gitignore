# ============================================================
# Unity .gitignore — Art Reality
# Basé sur https://github.com/github/gitignore/blob/main/Unity.gitignore
# ============================================================

# --- Unity generated folders ---
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Blender backup files
*.blend1
*.blend1.meta

# MemoryCaptures (gros fichiers, potentiellement sensibles)
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# --- IDE ---
# JetBrains Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Visual Studio Code
.vscode/

# --- Gradle / Android ---
.gradle/
ExportedObj/
.consulo/
*.tmp

# --- Crash / diagnostics ---
sysinfo.txt
mono_crash.*

# --- Builds ---
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.ipa

# Crashlytics
crashlytics-build.properties

# --- TestRunner ---
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# --- Addressables ---
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# --- Visual Scripting ---
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ============================================================
# AR Core Extensions — contient la clé API Google Cloud !
# ============================================================
ProjectSettings/ARCoreExtensionsProjectSettings.json
Assets/Settings/ARCoreExtensionsConfig.asset
Assets/Settings/ARCoreExtensionsConfig.asset.meta

# ============================================================
# External Dependency Manager (Google Play Services Resolver)
# Fichiers auto-générés par le resolver Android
# ============================================================
ProjectSettings/AndroidResolverDependencies.xml
ProjectSettings/GvhProjectSettings.xml
Assets/Plugins/Android/*.aar
Assets/Plugins/Android/*.jar
Assets/Plugins/Android/**/mainTemplate.gradle
Assets/Plugins/Android/**/gradleTemplate.properties

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/

# ============================================================
# Claude Code
# ============================================================
.claude/
.mcp.json
